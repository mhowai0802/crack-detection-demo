# HKBU GenAI (used by the backend /api/ai/* endpoints)
HKBU_API_KEY=your-hkbu-api-key-here
HKBU_BASE_URL=https://genai.hkbu.edu.hk/api/v0/rest
HKBU_MODEL=gpt-4.1-mini
HKBU_API_VERSION=2024-12-01-preview

# Backend (FastAPI)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated; use "*" to allow any origin during local dev.
BACKEND_CORS_ORIGINS=*
# cpu | cuda | auto
TORCH_DEVICE=auto

# Frontend (Streamlit) — where to reach the backend from the browser process
BACKEND_URL=http://localhost:8000
